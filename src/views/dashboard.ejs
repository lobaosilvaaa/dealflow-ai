<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        DealFlow AI Dashboard
    </title>

    <!-- 🎨 CSS -->
    <link rel="stylesheet" href="/css/dashboard.css">

    <!-- 📈 Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body data-promos="<%= sentPromos %>" data-users="<%= totalUsers %>">

    <!-- 🚀 Topbar -->
    <div class="topbar">

        <div>

            <h1>
                🚀 DealFlow AI Dashboard
            </h1>

            <p class="subtitle">

                Plataforma SaaS de automação inteligente

            </p>

        </div>

        <div class="topbar-actions">

            <div class="environment-badge">

                🌎
                <%= environment || "development" %>

            </div>

            <a href="/logout" class="logout">

                🚪 Logout

            </a>

        </div>

    </div>

    <!-- 📊 Cards -->
    <div class="cards">

        <!-- 📤 Promoções -->
        <div class="card">

            <h2>
                📤 Promoções enviadas
            </h2>

            <p id="promosCount">
                <%= sentPromos %>
            </p>

        </div>

        <!-- 👥 Usuários -->
        <div class="card">

            <h2>
                👥 Usuários registrados
            </h2>

            <p id="usersCount">
                <%= totalUsers %>
            </p>

        </div>

        <!-- ⏱️ Uptime -->
        <div class="card">

            <h2>
                ⏱️ Uptime
            </h2>

            <p id="uptimeCount">

                <%= Math.floor(uptime) %>s

            </p>

        </div>

        <!-- 💾 Memória -->
        <div class="card">

            <h2>
                💾 Memória
            </h2>

            <p id="memoryCount">

                <%= memoryUsage || 0 %> MB

            </p>

        </div>

    </div>

    <!-- 📈 Analytics -->
    <div class="card">

        <div class="section-header">

            <h2>
                📈 Analytics
            </h2>

            <span class="live-badge">

                🟢 LIVE

            </span>

        </div>

        <div class="analytics-wrapper">

            <canvas id="promoChart"></canvas>

        </div>

    </div>

    <!-- 📜 Logs -->
    <div class="card">

        <div class="section-header">

            <h2>
                📜 Logs Recentes
            </h2>

            <span class="live-badge">

                ⚡ Realtime

            </span>

        </div>

        <div class="logs-container" id="logsContainer">

            <% if (logs.length===0) { %>

                <div class="log-item">

                    Nenhum log encontrado.

                </div>

                <% } %>

                    <% logs.forEach(log=> { %>

                        <div class="log-item">

                            <%= log %>

                        </div>

                        <% }) %>

        </div>

    </div>

    <!-- 👥 Usuários -->
    <div class="card">

        <div class="section-header">

            <h2>
                👥 Usuários
            </h2>

            <span class="live-badge">

                <%= totalUsers %> online

            </span>

        </div>

        <div class="table-wrapper">

            <table>

                <thead>

                    <tr>

                        <th>
                            Chat ID
                        </th>

                        <th>
                            Categoria
                        </th>

                        <th>
                            Frequência
                        </th>

                        <th>
                            Status
                        </th>

                        <th>
                            Ações
                        </th>

                    </tr>

                </thead>

                <tbody>

                    <% if (users.length===0) { %>

                        <tr>

                            <td colspan="5">

                                Nenhum usuário registrado.

                            </td>

                        </tr>

                        <% } %>

                            <% users.forEach(user=> { %>

                                <tr>

                                    <td>

                                        <%= user.chat_id %>

                                    </td>

                                    <td>

                                        <%= user.category %>

                                    </td>

                                    <td>

                                        <%= user.frequency %> min

                                    </td>

                                    <td>

                                        <% if (user.active) { %>

                                            <span class="status-active">

                                                🟢 Ativo

                                            </span>

                                            <% } else { %>

                                                <span class="status-paused">

                                                    🔴 Pausado

                                                </span>

                                                <% } %>

                                    </td>

                                    <td>

                                        <div class="actions">

                                            <% if (user.active) { %>

                                                <form method="POST" action="/admin/pause/<%= user.chat_id %>">

                                                    <button class="btn-pause" type="submit">

                                                        ⏸️ Pausar

                                                    </button>

                                                </form>

                                                <% } else { %>

                                                    <form method="POST" action="/admin/activate/<%= user.chat_id %>">

                                                        <button class="btn-activate" type="submit">

                                                            ▶️ Ativar

                                                        </button>

                                                    </form>

                                                    <% } %>

                                                        <form method="POST" action="/admin/delete/<%= user.chat_id %>"
                                                            onsubmit="return confirm('Deseja remover este usuário?')">

                                                            <button class="btn-delete" type="submit">

                                                                🗑️ Remover

                                                            </button>

                                                        </form>

                                        </div>

                                    </td>

                                </tr>

                                <% }) %>

                </tbody>

            </table>

        </div>

    </div>

    <!-- ⚙️ System Info -->
    <div class="card">

        <div class="section-header">

            <h2>
                ⚙️ System Info
            </h2>

        </div>

        <div class="system-grid">

            <div class="system-item">

                <strong>
                    🌎 Ambiente:
                </strong>

                <span>

                    <%= environment || "development" %>

                </span>

            </div>

            <div class="system-item">

                <strong>
                    🟢 Node:
                </strong>

                <span>

                    <%= nodeVersion || "N/A" %>

                </span>

            </div>

            <div class="system-item">

                <strong>
                    💾 RAM:
                </strong>

                <span>

                    <%= memoryUsage || 0 %> MB

                </span>

            </div>

        </div>

    </div>

    <!-- 🔌 Socket.IO -->
    <script src="/socket.io/socket.io.js"></script>

    <!-- 🚀 Dashboard JS -->
    <script src="/js/dashboard.js"></script>

</body>

</html>