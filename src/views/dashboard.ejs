<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        DealFlow AI Dashboard
    </title>

    <!-- 🎨 CSS -->
    <link rel="stylesheet" href="/css/dashboard.css">

    <!-- 📈 Chart.js -->
    <script src="/js/chart.min.js"></script>

</head>

<body data-promos="<%= sentPromos %>" data-users="<%= totalUsers %>">

    <!-- 🌌 Background FX -->
    <div class="background-overlay"></div>

    <!-- 🚀 Topbar -->
    <header class="topbar">

        <div>

            <h1>
                🚀 DealFlow AI Dashboard
            </h1>

            <p class="subtitle">
                Plataforma SaaS de automação inteligente,
                analytics realtime e observabilidade.
            </p>

        </div>

        <div class="topbar-actions">

            <div class="environment-badge">

                🟢 ONLINE

            </div>

            <a href="/logout" class="logout">

                🚪 Logout

            </a>

        </div>

    </header>

    <!-- 📊 Metrics -->
    <section class="cards">

        <!-- 📤 Promos -->
        <div class="card metric-card">

            <div class="metric-header">

                <span>
                    📤 Promoções enviadas
                </span>

            </div>

            <p id="promosCount">
                <%= sentPromos %>
            </p>

        </div>

        <!-- 👥 Users -->
        <div class="card metric-card">

            <div class="metric-header">

                <span>
                    👥 Usuários registrados
                </span>

            </div>

            <p id="usersCount">
                <%= totalUsers %>
            </p>

        </div>

        <!-- ⏱️ Uptime -->
        <div class="card metric-card">

            <div class="metric-header">

                <span>
                    ⏱️ Uptime
                </span>

            </div>

            <p id="uptimeCount">
                <%= Math.floor(uptime) %>s
            </p>

        </div>

        <!-- 💾 Memory -->
        <div class="card metric-card">

            <div class="metric-header">

                <span>
                    💾 Memória
                </span>

            </div>

            <p id="memoryCount">
                <%= memoryUsage || 0 %> MB
            </p>

        </div>

    </section>

    <!-- 📈 Analytics -->
    <section class="card">

        <div class="section-header">

            <h2>
                📈 Analytics
            </h2>

            <div class="live-badge">

                🟢 LIVE

            </div>

        </div>

        <div class="analytics-wrapper">

            <canvas id="promoChart"></canvas>

        </div>

    </section>

    <!-- 📜 Logs -->
    <section class="card">

        <div class="section-header">

            <h2>
                📜 Logs Recentes
            </h2>

            <div class="live-badge">

                ⚡ Realtime

            </div>

        </div>

        <div class="logs-container" id="logsContainer">

            <% if (logs && logs.length> 0) { %>

                <% logs.forEach(log=> { %>

                    <div class="log-item">

                        <%= log %>

                    </div>

                    <% }) %>

                        <% } else { %>

                            <div class="empty-state">

                                Nenhum log encontrado.

                            </div>

                            <% } %>

        </div>

    </section>

    <!-- 👥 Usuários -->
    <section class="card">

        <div class="section-header">

            <h2>
                👥 Usuários
            </h2>

            <div class="live-badge">

                <%= totalUsers %> online

            </div>

        </div>

        <div class="table-wrapper">

            <table>

                <thead>

                    <tr>

                        <th>
                            Chat ID
                        </th>

                        <th>
                            Categoria
                        </th>

                        <th>
                            Frequência
                        </th>

                        <th>
                            Status
                        </th>

                        <th>
                            Ações
                        </th>

                    </tr>

                </thead>

                <tbody>

                    <% if (users && users.length> 0) { %>

                        <% users.forEach(user=> { %>

                            <tr>

                                <td>
                                    <%= user.chat_id %>
                                </td>

                                <td>
                                    <%= user.category %>
                                </td>

                                <td>
                                    <%= user.frequency %> min
                                </td>

                                <td>

                                    <% if (user.active) { %>

                                        <span class="status-active">

                                            🟢 Ativo

                                        </span>

                                        <% } else { %>

                                            <span class="status-paused">

                                                🔴 Pausado

                                            </span>

                                            <% } %>

                                </td>

                                <td>

                                    <div class="actions">

                                        <% if (user.active) { %>

                                            <form method="POST" action="/admin/pause/<%= user.chat_id %>">

                                                <button class="btn-pause">

                                                    ⏸️ Pausar

                                                </button>

                                            </form>

                                            <% } else { %>

                                                <form method="POST" action="/admin/activate/<%= user.chat_id %>">

                                                    <button class="btn-activate">

                                                        ▶️ Ativar

                                                    </button>

                                                </form>

                                                <% } %>

                                                    <form method="POST" action="/admin/delete/<%= user.chat_id %>">

                                                        <button class="btn-delete">

                                                            🗑️ Remover

                                                        </button>

                                                    </form>

                                    </div>

                                </td>

                            </tr>

                            <% }) %>

                                <% } else { %>

                                    <tr>

                                        <td colspan="5">

                                            <div class="empty-state">

                                                Nenhum usuário registrado.

                                            </div>

                                        </td>

                                    </tr>

                                    <% } %>

                </tbody>

            </table>

        </div>

    </section>

    <!-- ⚙️ System -->
    <section class="card">

        <div class="section-header">

            <h2>
                ⚙️ System Info
            </h2>

        </div>

        <div class="system-grid">

            <div class="system-item">

                <span>
                    🌎 Ambiente
                </span>

                <strong>
                    development
                </strong>

            </div>

            <div class="system-item">

                <span>
                    ⚡ Node.js
                </span>

                <strong>
                    <%= process.version %>
                </strong>

            </div>

            <div class="system-item">

                <span>
                    💾 RAM
                </span>

                <strong>
                    <%= memoryUsage || 0 %> MB
                </strong>

            </div>

            <div class="system-item">

                <span>
                    🔌 Socket.IO
                </span>

                <strong>
                    ONLINE
                </strong>

            </div>

        </div>

    </section>

    <!-- 🔌 Socket.IO -->
    <script src="/socket.io/socket.io.js"></script>

    <!-- 🚀 Dashboard JS -->
    <script src="/js/dashboard.js"></script>

</body>

</html>