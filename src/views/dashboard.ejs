<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <title>
        DealFlow AI Dashboard
    </title>

    <!-- 🎨 CSS -->
    <link rel="stylesheet" href="/css/dashboard.css">

    <!-- 📈 Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body data-promos="<%= sentPromos %>" data-users="<%= totalUsers %>">

    <!-- 🚀 Topbar -->
    <div class="topbar">

        <h1>
            🚀 DealFlow AI Dashboard
        </h1>

        <a href="/logout" class="logout">
            🚪 Logout
        </a>

    </div>

    <!-- 📊 Cards -->
    <div class="cards">

        <div class="card">

            <h2>
                📤 Promoções enviadas
            </h2>

            <p>
                <%= sentPromos %>
            </p>

        </div>

        <div class="card">

            <h2>
                👥 Usuários registrados
            </h2>

            <p>
                <%= totalUsers %>
            </p>

        </div>

        <div class="card">

            <h2>
                ⏱️ Uptime
            </h2>

            <p>
                <%= Math.floor(uptime) %>s
            </p>

        </div>

    </div>

    <!-- 📈 Analytics -->
    <div class="card">

        <h2>
            📈 Analytics
        </h2>

        <div class="analytics-wrapper">

            <canvas id="promoChart"></canvas>

        </div>

    </div>

    <!-- 📜 Logs -->
    <div class="card">

        <h2>
            📜 Logs Recentes
        </h2>

        <div class="logs-container" id="logsContainer">

            <% logs.forEach(log=> { %>

                <div class="log-item">

                    <%= log %>

                </div>

                <% }) %>

        </div>

    </div>

    <!-- 👥 Usuários -->
    <table>

        <thead>

            <tr>

                <th>
                    Chat ID
                </th>

                <th>
                    Categoria
                </th>

                <th>
                    Frequência
                </th>

                <th>
                    Status
                </th>

                <th>
                    Ações
                </th>

            </tr>

        </thead>

        <tbody>

            <% users.forEach(user=> { %>

                <tr>

                    <td>
                        <%= user.chat_id %>
                    </td>

                    <td>
                        <%= user.category %>
                    </td>

                    <td>
                        <%= user.frequency %> min
                    </td>

                    <td>

                        <% if (user.active) { %>

                            <span class="status-active">
                                🟢 Ativo
                            </span>

                            <% } else { %>

                                <span class="status-paused">
                                    🔴 Pausado
                                </span>

                                <% } %>

                    </td>

                    <td>

                        <div class="actions">

                            <% if (user.active) { %>

                                <form method="POST" action="/admin/pause/<%= user.chat_id %>">

                                    <button class="btn-pause">
                                        ⏸️ Pausar
                                    </button>

                                </form>

                                <% } else { %>

                                    <form method="POST" action="/admin/activate/<%= user.chat_id %>">

                                        <button class="btn-activate">
                                            ▶️ Ativar
                                        </button>

                                    </form>

                                    <% } %>

                                        <form method="POST" action="/admin/delete/<%= user.chat_id %>">

                                            <button class="btn-delete">
                                                🗑️ Remover
                                            </button>

                                        </form>

                        </div>

                    </td>

                </tr>

                <% }) %>

        </tbody>

    </table>

    <!-- 🚀 Dashboard JS -->
    <script src="/js/dashboard.js"></script>

    <!-- 🔌 Socket.IO -->
    <script src="/socket.io/socket.io.js"></script>

    <script>

        const socket = io();

        // 📡 Novo log realtime
        socket.on("new-log", data => {

            console.log(
                "Novo log:",
                data.message
            );

            const logsContainer =
                document.getElementById(
                    "logsContainer"
                );

            const logItem =
                document.createElement("div");

            logItem.classList.add(
                "log-item"
            );

            logItem.innerText =
                data.message;

            logsContainer.prepend(
                logItem
            );

        });

    </script>

</body>

</html>